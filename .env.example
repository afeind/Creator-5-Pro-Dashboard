# Copy this file to `.env` and fill in your own values.
#   cp .env.example .env
#
# `.env` is gitignored — never commit it. The access code is a credential:
# anyone who has it, plus network access to the printer, can control it.

# ---- Required ----------------------------------------------------------

# Your printer's IP address on the LAN.
PRINTER_HOST=192.168.1.100

# Printer serial number. Two ways to get it:
#   1. Printer touchscreen, under device/about info.
#   2. Over the network, no credentials needed — see "Finding your
#      serial and access code" in the README:
#        python3 -c "import socket;s=socket.socket(2,2);s.settimeout(3);\
#        s.sendto(b'x',('192.168.1.100',48899));print(s.recvfrom(2048)[0])"
PRINTER_SERIAL=SNXXXXXXXXXXX

# Access code / "check code". This is ONLY visible on the printer's own
# touchscreen (network or connection settings) — it cannot be discovered
# over the network. Every API call is rejected without it.
PRINTER_CHECK_CODE=xxxxxxxx

# ---- Optional (defaults shown) ----------------------------------------

PRINTER_API_PORT=8898
PRINTER_CAM_PORT=8080
PRINTER_CAM_PATH=/?action=stream
DATA_DIR=/data
